MEDIASERVER_PUBLIC_HOST=192.168.0.90
MAX_UPLOAD_BYTES=53687091200

STORAGE_VOLUMES=default:/videos:Varsayılan (data/videos)|./data/videos

# Panelden gezilebilir disk kökleri (id:konteyner:etiket|pc_yolu)
STORAGE_BROWSE_ROOTS=media:/host/media:Media diski|/media;mnt:/host/mnt:Mount (/mnt)|/mnt;extra:/host/extra:Ek disk|/host/extra

# Ek disk (ör. /media/micae/store veya /home/micae/Disk) — compose mount ile aynı olmalı:
# STORAGE_EXTRA_HOST_PATH=/media/micae/store
# STORAGE_BROWSE_ROOTS=media:/host/media:/media;store:/host/extra:Mağaza diski|/media/micae/store
